          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT conversation_id) AS \"Total Conversations\" FROM chat_events WHERE $__timeFilter(timestamp) AND inbox IN ($inbox)",
