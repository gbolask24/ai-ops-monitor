        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  provider || '/' || model AS \"Model\",\n  ROUND(SUM(estimated_cost)::numeric, 4) AS \"Total Cost ($)\",\n  SUM(total_tokens) AS \"Total Tokens\"\nFROM ai_requests\nWHERE $__timeFilter(timestamp)\n  AND estimated_cost IS NOT NULL\nGROUP BY provider, model\nORDER BY SUM(estimated_cost) DESC\nLIMIT 5",
          "refId": "A"
        }
      ],
      "title": "Top 5 Most Expensive Models",
      "type": "table"
    }
