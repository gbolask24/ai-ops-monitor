      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 16 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "timestamp" }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT timestamp, 'ai' AS source, conversation_id AS identifier,\n       provider || '/' || model AS detail,\n       COALESCE(error_type, CASE WHEN escalated THEN 'escalated' WHEN fallback_used THEN 'fallback' END) AS status,\n       latency_ms AS \"duration/latency\"\nFROM ai_requests\nWHERE $__timeFilter(timestamp)\n  AND (error_type IS NOT NULL OR fallback_used = true OR escalated = true)\n\nUNION ALL\n\nSELECT timestamp, 'workflow', execution_id,\n       workflow_name, status, duration_ms\nFROM workflow_runs\nWHERE $__timeFilter(timestamp)\n  AND status != 'success'\n\nUNION ALL\n\nSELECT timestamp, 'chat', conversation_id,\n       event_type, agent_type, NULL::int\nFROM chat_events\nWHERE $__timeFilter(timestamp)\n  AND event_type = 'human_handoff'\n\nORDER BY timestamp DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Recent Incidents",
      "type": "table"
