      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(SUM(CASE WHEN schema_valid = true THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(schema_valid), 0) * 100, 1) AS \"Schema Pass Rate %\" FROM ai_requests WHERE $__timeFilter(timestamp) AND provider IN ($provider)",
