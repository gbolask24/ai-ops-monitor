    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
      "description": "Recent failures, escalations, and handoffs across all systems",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
