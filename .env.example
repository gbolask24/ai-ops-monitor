# Postgres
POSTGRES_DB=monitoring
POSTGRES_USER=monitor
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# Webhook receiver (used by app container)
# Update the password below to match POSTGRES_PASSWORD
DATABASE_URL=postgresql://monitor:CHANGE_ME@postgres:5432/monitoring

# For scripts running on the host (outside Docker network)
# Update the password below to match POSTGRES_PASSWORD
DATABASE_URL_HOST=postgresql://monitor:CHANGE_ME@localhost:5432/monitoring
