    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
      "description": "Average and p95 latency over time by hour",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', timestamp) AS time,\n  AVG(latency_ms)::int AS \"Avg Latency (ms)\",\n  percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms)::int AS \"P95 Latency (ms)\"\nFROM ai_requests\nWHERE $__timeFilter(timestamp)\n  AND latency_ms IS NOT NULL\n  AND provider IN ($provider)\n  AND model IN ($model)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "AI Response Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
