      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', timestamp) AS time,\n  SUM(CASE WHEN escalated = true THEN 1 ELSE 0 END) AS \"Escalations\",\n  SUM(CASE WHEN fallback_used = true THEN 1 ELSE 0 END) AS \"Fallbacks\"\nFROM ai_requests\nWHERE $__timeFilter(timestamp)\n  AND provider IN ($provider)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Escalation & Fallback Trends",
      "type": "timeseries"
    },
    {
