        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', timestamp) AS time,\n  model,\n  SUM(estimated_cost)::numeric(10,4) AS \"Cost ($)\"\nFROM ai_requests\nWHERE $__timeFilter(timestamp)\n  AND estimated_cost IS NOT NULL\n  AND provider IN ($provider)\n  AND model IN ($model)\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Token & Cost Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
