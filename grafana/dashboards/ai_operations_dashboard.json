        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Total Runs\" FROM workflow_runs WHERE $__timeFilter(timestamp) AND workflow_name IN ($workflow_name)",
          "refId": "A"
        },
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(SUM(CASE WHEN status = 'success' THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS \"Success Rate %\" FROM workflow_runs WHERE $__timeFilter(timestamp) AND workflow_name IN ($workflow_name)",
          "refId": "B"
        },
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(SUM(CASE WHEN status = 'failed' THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS \"Failure Rate %\" FROM workflow_runs WHERE $__timeFilter(timestamp) AND workflow_name IN ($workflow_name)",
          "refId": "C"
        }
      ],
