      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ai-ops-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  workflow_name AS \"Workflow\",\n  ROUND(AVG(duration_ms)) AS \"Avg Duration (ms)\",\n  COUNT(*) AS \"Runs\"\nFROM workflow_runs\nWHERE $__timeFilter(timestamp)\nGROUP BY workflow_name\nORDER BY AVG(duration_ms) DESC\nLIMIT 5",
          "refId": "A"
        }
      ],
      "title": "Top 5 Slowest Workflows",
      "type": "table"
