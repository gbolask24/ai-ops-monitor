            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "duration/latency" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.width", "value": 120 }]
          }
        ]
